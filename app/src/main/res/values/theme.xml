<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

	<style name="NightAdjusted.Theme.BetterUntis" parent="android:Theme.Material.Light.NoActionBar" />

	<style name="Theme.BetterUntis" parent="NightAdjusted.Theme.BetterUntis">
		<item name="android:forceDarkAllowed" tools:targetApi="29">false</item>
	</style>

	<style name="NightAdjusted.Theme.Splash" parent="Theme.SplashScreen">
		<item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
		<item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
	</style>

	<style name="Theme.BetterUntis.Splash" parent="NightAdjusted.Theme.Splash">
		<item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
		<item name="postSplashScreenTheme">@style/Theme.BetterUntis</item>
	</style>

</resources>
